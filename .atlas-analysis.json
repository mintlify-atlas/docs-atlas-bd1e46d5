  "keyFeatures": [
    "Real-time video synchronization across multiple users",
    "No account registration required for basic usage",
    "Bookmarkable rooms with custom URLs",
    "Support for YouTube, Vimeo, and direct media files",
    "Vote mode and vote-to-skip functionality",
    "Room permissions and user management",
    "SponsorBlock integration for automatic sponsor skipping",
    "Text chat and user lists",
    "Multiple UI themes",
    "Self-hostable with Docker support"
  ],
  "publicApiSurface": [
    "GET /api/room/list - List public rooms",
    "POST /api/room/{RoomName}/queue - Add video to queue",
    "GET /api/room/{RoomName} - Get room details",
    "POST /api/room/create - Create a new room",
    "POST /api/data/previewAdd - Preview video metadata",
    "GET /api/user - Get current user info",
    "WebSocket /api/room/{RoomName} - Real-time room events",
    "Room.addToQueue() - Add video to room queue",
    "Room.playbackStart() - Start playback",
    "Room.playbackPause() - Pause playback",
    "Room.skip() - Skip current video",
    "ClientManager - Manages WebSocket connections",
    "RoomManager - Manages room lifecycle",
    "InfoExtractor - Extracts video metadata from URLs"
  ]
}
